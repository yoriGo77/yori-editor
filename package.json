    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.2",
    "eslint": "^9.30.1",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "globals": "^14.0.0",
    "jiti": "^2.6.1",
    "obsidian": "^1.8.7",
